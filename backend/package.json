{
  "name": "vtb-backend",
  "version": "1.0.0",
  "description": "VTB Backend - Express + SQLite + Web3 Relayer",
  "main": "src/index.ts",
  "scripts": {
    "start": "tsx src/index.ts",
    "dev": "nodemon --exec tsx src/index.ts",
    "build": "tsc",
    "seed": "tsx src/scripts/seedDatabase.ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "backend",
    "express",
    "sqlite",
    "web3",
    "ethereum",
    "blockchain"
  ],
  "author": "Senior Web3 Architect",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "ethers": "^6.11.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.5.1",
    "jsonwebtoken": "^9.0.2",
    "sqlite3": "^5.1.7"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/express-rate-limit": "^5.1.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.10.6",
    "nodemon": "^3.0.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.3.3"
  }
}
