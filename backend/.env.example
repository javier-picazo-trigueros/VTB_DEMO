PORT=3001
DATABASE_URL=./vtb.db
JWT_SECRET=super-secret-jwt-key-change-in-production
HMAC_SECRET=super-secret-hmac-key-change-in-production
NULLIFIER_SECRET=super-secret-nullifier-key-change-in-production
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
NODE_ENV=development

# ── Blockchain ─────────────────────────────────────────────────────────────
# Address of the deployed ElectionRegistry contract.
# Run `npx hardhat run scripts/deploy.ts --network sepolia` and copy the address.
CONTRACT_ADDRESS=0xF6909eaF37D33b51333a282c4b3750981Bc768a4

# Private key of the relayer wallet used to sign castVote transactions.
# For local Hardhat: use account #0 (never use this key in production).
PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# Alchemy RPC (HTTP for backend transactions)
# Get your key at: dashboard.alchemy.com
RPC_URL=https://eth-sepolia.g.alchemy.com/v2/SqiqmYnoP6S-R7kGyFM8T
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/SqiqmYnoP6S-R7kGyFM8T
ALCHEMY_API_KEY=SqiqmYnoP6S-R7kGyFM8T

# Block explorer base URL (used to build /tx/<hash> links in audit records).
# Sepolia: https://sepolia.etherscan.io
EXPLORER_URL=https://sepolia.etherscan.io
