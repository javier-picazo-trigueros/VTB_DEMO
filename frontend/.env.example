# VTB Frontend — Environment Variables
# =====================================
# Copy to .env.local and adjust values.

# Backend API base URL
VITE_API_URL=http://localhost:3001

# ── Blockchain ─────────────────────────────────────────────────────────────
# JSON-RPC endpoint that the frontend uses to connect to the blockchain node.
# Hardhat local: http://localhost:8545
# Sepolia:       use Alchemy/Infura public URL
VITE_RPC_URL=http://localhost:8545

# Deployed ElectionRegistry contract address.
# Must match the address printed by `npx hardhat run scripts/deploy.ts`.
VITE_CONTRACT_ADDRESS=0x5FbDB2315678afecb367f032d93F642f64180aa3

# Block explorer base URL used to build clickable transaction links.
# Leave empty for local Hardhat (no explorer available).
# Sepolia: https://sepolia.etherscan.io
# Custom:  http://<your-explorer>
VITE_EXPLORER_URL=
