# VTB Frontend — Environment Variables
# =====================================
# Copy to .env.local and adjust values.

# Backend API base URL
VITE_API_URL=http://localhost:3001

# ── Blockchain ─────────────────────────────────────────────────────────────
# Alchemy WebSocket (for real-time VoteCast event listener)
# Get your key at: dashboard.alchemy.com
# Hardhat local: http://localhost:8545
VITE_RPC_URL=wss://eth-sepolia.g.alchemy.com/v2/SqiqmYnoP6S-R7kGyFM8T

# Deployed ElectionRegistry contract address.
# Must match the address printed by `npx hardhat run scripts/deploy.ts --network sepolia`.
VITE_CONTRACT_ADDRESS=0xF6909eaF37D33b51333a282c4b3750981Bc768a4

# Block explorer base URL used to build clickable transaction links.
# Sepolia: https://sepolia.etherscan.io
VITE_EXPLORER_URL=https://sepolia.etherscan.io
